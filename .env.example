# Copy to .env (the real file is git-ignored) and fill in your Groq key.
# Get one at https://console.groq.com — the free tier is plenty for testing.

RECALLWELL_GROQ_API_KEY=gsk_your_key_here

# Optional: publish the container on a different host port.
# RECALLWELL_PUBLIC_PORT=7676

# Optional: turn the logs up.
# RUST_LOG=debug,recallwell=trace
